<table border="1">
<tr>
<td><pre>UPDATE table_name [alias]
  SET column_name1 = value1
     [, column_name2 = value2...]
      [WHERE condition]</pre>
</td>
<td>UPDATE students
<p>SET scholarship=scholarship*0.15
WHERE scholarship&lt;300;
</p>
</td></tr>
<tr>
<td><pre>UPDATE table_name [alias]
  SET (column_name1 [,column_name2]...) = (subquery)
    [WHERE condition]</pre>
</td>
<td>
</td></tr></table>
